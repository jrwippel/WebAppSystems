@model WebAppSystems.Models.Mensalista

@{
    ViewData["Title"] = "Novo Mensalista";
}

<div class="page-container">
    <div class="page-header">
        <div class="page-header-icon"><i class="bi bi-calendar-check"></i></div>
        <div>
            <h2>Cadastro de Mensalista</h2>
            <p>Defina os valores mensais por cliente</p>
        </div>
    </div>

    <div class="form-card">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="form-field">
                <label asp-for="ClientId">Cliente</label>
                <select asp-for="ClientId" class="form-control" asp-items="ViewBag.Clients" id="clienteSelect"></select>
            </div>

            <div class="form-grid">
                <div class="form-field">
                    <label asp-for="ValorMensalBruto">Valor Mensal Bruto (R$)</label>
                    <input asp-for="ValorMensalBruto" class="form-control" pattern="^[0-9]+([.,][0-9]{1,2})?$" data-val="false" placeholder="0,00" />
                    <span asp-validation-for="ValorMensalBruto" class="text-danger"></span>
                </div>
                <div class="form-field">
                    <label asp-for="ComissaoParceiro">Comissão Parceiro (%)</label>
                    <input asp-for="ComissaoParceiro" class="form-control" pattern="^[0-9]+([.,][0-9]{1,2})?$" data-val="false" placeholder="0,00" />
                    <span asp-validation-for="ComissaoParceiro" class="text-danger"></span>
                </div>
                <div class="form-field">
                    <label asp-for="ComissaoSocio">Comissão Sócio (%)</label>
                    <input asp-for="ComissaoSocio" class="form-control" pattern="^[0-9]+([.,][0-9]{1,2})?$" data-val="false" placeholder="0,00" />
                    <span asp-validation-for="ComissaoSocio" class="text-danger"></span>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-save"><i class="bi bi-check-lg"></i> Salvar</button>
                <a asp-action="Index" class="btn-back"><i class="bi bi-arrow-left"></i> Voltar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        $(document).ready(function () {
            $("#clienteSelect").select2({ placeholder: "Selecione um cliente", allowClear: true });
        });
    </script>
}
