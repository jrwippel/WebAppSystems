@model WebAppSystems.Models.ValorCliente

@{
    ViewData["Title"] = "Novo Valor";
}

<div class="page-container">
    <div class="page-header">
        <div class="page-header-icon"><i class="bi bi-cash-coin"></i></div>
        <div>
            <h2>Valores por Cliente</h2>
            <p>Cadastro de valor hora por cliente e advogado/sócio</p>
        </div>
    </div>

    <div class="form-card">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="form-field">
                <label asp-for="ClientId">Cliente</label>
                <select asp-for="ClientId" class="form-control" asp-items="ViewBag.ClientId"></select>
            </div>
            <div class="form-field">
                <label asp-for="AttorneyId">Advogado/Sócio</label>
                <select asp-for="AttorneyId" class="form-control" asp-items="ViewBag.AttorneyId"></select>
            </div>
            <div class="form-field">
                <label asp-for="Valor">Valor (R$/h)</label>
                @Html.TextBoxFor(model => model.Valor, new { @class = "form-control", data_val = "false", placeholder = "0,00" })
                <span asp-validation-for="Valor" class="text-danger"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-save"><i class="bi bi-check-lg"></i> Salvar</button>
                <a asp-action="Index" class="btn-back"><i class="bi bi-arrow-left"></i> Voltar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
