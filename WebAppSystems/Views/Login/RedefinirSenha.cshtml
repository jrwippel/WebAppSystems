@model RedefinirSenhaModel
@{
    Layout = "_LayoutDeslogado";
    ViewData["Title"] = "Redefinir a Senha";
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Password - JRWIT Solutions</title>
    <link href="/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/lib/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link href="/css/custom-styles.css" rel="stylesheet">
</head>
<body>
    <div class="login-page">
        <div class="login-wrapper" style="max-width: 500px;">
            <div class="login-right" style="padding: 50px 40px;">
                <div class="login-card">
                    <div class="login-header">
                        <div class="icon-wrapper">
                            <i class="bi bi-key"></i>
                        </div>
                        <h2>Reset Password</h2>
                        <p>Enter your credentials to receive a new password</p>
                    </div>

                    @if (TempData["MensagemErro"] != null)
                    {
                        <div class="alert alert-danger">
                            <i class="bi bi-exclamation-circle"></i>
                            @TempData["MensagemErro"]
                        </div>
                    }

                    @if (TempData["MensagemSucesso"] != null)
                    {
                        <div class="alert alert-success">
                            <i class="bi bi-check-circle"></i>
                            @TempData["MensagemSucesso"]
                        </div>
                    }

                    <form asp-controller="Login" asp-action="EnviarLinkParaRedefinirSenha" method="post" class="login-form">
                        <div class="form-group">
                            <label for="login">Username</label>
                            <div class="input-group">
                                <span class="input-icon">
                                    <i class="bi bi-person"></i>
                                </span>
                                <input type="text" 
                                       asp-for="Login" 
                                       class="form-control" 
                                       id="login" 
                                       placeholder="Enter your username">
                            </div>
                            @Html.ValidationMessageFor(x => x.Login, "", new { @class = "text-danger" })
                        </div>

                        <div class="form-group">
                            <label for="email">Email</label>
                            <div class="input-group">
                                <span class="input-icon">
                                    <i class="bi bi-envelope"></i>
                                </span>
                                <input type="email" 
                                       asp-for="Email" 
                                       class="form-control" 
                                       id="email" 
                                       placeholder="Enter your email">
                            </div>
                            @Html.ValidationMessageFor(x => x.Email, "", new { @class = "text-danger" })
                        </div>

                        <button type="submit" class="btn-login">
                            Send New Password
                            <i class="bi bi-send"></i>
                        </button>

                        <a asp-controller="Login" asp-action="Index" class="btn-back">
                            <i class="bi bi-arrow-left"></i>
                            Back to Login
                        </a>
                    </form>
                </div>

                <div class="brand-footer">
                    <span class="brand-text">JRWIT.COM</span>
                    <span class="brand-tagline">SMART SOLUTIONS FOR YOUR BUSINESS</span>
                </div>
            </div>
        </div>
    </div>

    <script src="/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>