@model RedefinirSenhaModel
@{
    Layout = "_LayoutDeslogado";
    ViewData["Title"] = "Redefinir Senha";
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Password - JRWIT Solutions</title>
    <link href="/lib/bootstrap/dist/css/bootstrap.min.css?v=2" rel="stylesheet">
    <link href="/lib/bootstrap-icons/font/bootstrap-icons.css?v=2" rel="stylesheet">
    <link href="/css/custom-styles.css?v=2" rel="stylesheet">
</head>
<body>
    <div class="login-page">
        <div class="login-wrapper">

            <!-- Left Side -->
            <div class="login-left">
                <div class="brand-section">
                    <div class="brand-logo-container">
                        <div class="logo-text">
                            <div class="logo-icon-large">
                                <i class="bi bi-shield-lock"></i>
                            </div>
                            <h1 class="logo-title">Password Reset</h1>
                            <p class="logo-subtitle">Secure account recovery</p>
                        </div>
                    </div>

                    <div class="features-list">
                        <div class="feature-item">
                            <div class="feature-icon"><i class="bi bi-envelope-check"></i></div>
                            <div class="feature-text">
                                <h3>Email Verification</h3>
                                <p>We verify your identity via email</p>
                            </div>
                        </div>
                        <div class="feature-item">
                            <div class="feature-icon"><i class="bi bi-key"></i></div>
                            <div class="feature-text">
                                <h3>Temporary Password</h3>
                                <p>A new password will be sent to you</p>
                            </div>
                        </div>
                        <div class="feature-item">
                            <div class="feature-icon"><i class="bi bi-lock"></i></div>
                            <div class="feature-text">
                                <h3>Stay Secure</h3>
                                <p>Change your password after login</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Side -->
            <div class="login-right">
                <div class="login-card">
                    <div class="login-header">
                        <div class="icon-wrapper">
                            <i class="bi bi-key"></i>
                        </div>
                        <h2>Reset Password</h2>
                        <p>Enter your credentials to receive a new password</p>
                    </div>

                    @if (TempData["MensagemErro"] != null)
                    {
                        <div class="alert alert-danger">
                            <i class="bi bi-exclamation-circle"></i>
                            @TempData["MensagemErro"]
                        </div>
                    }
                    @if (TempData["MensagemSucesso"] != null)
                    {
                        <div class="alert alert-success">
                            <i class="bi bi-check-circle"></i>
                            @TempData["MensagemSucesso"]
                        </div>
                    }

                    <form asp-controller="Login" asp-action="EnviarLinkParaRedefinirSenha" method="post" class="login-form">
                        <div class="form-group">
                            <label for="login">Username</label>
                            <div class="input-group">
                                <span class="input-icon"><i class="bi bi-person"></i></span>
                                <input type="text" asp-for="Login" class="form-control" id="login"
                                       placeholder="Enter your username" autocomplete="off">
                            </div>
                            @Html.ValidationMessageFor(x => x.Login, "", new { @class = "text-danger" })
                        </div>

                        <div class="form-group">
                            <label for="email">Email</label>
                            <div class="input-group">
                                <span class="input-icon"><i class="bi bi-envelope"></i></span>
                                <input type="email" asp-for="Email" class="form-control" id="email"
                                       placeholder="Enter your email" autocomplete="off">
                            </div>
                            @Html.ValidationMessageFor(x => x.Email, "", new { @class = "text-danger" })
                        </div>

                        <button type="submit" class="btn-login">
                            Send New Password
                            <i class="bi bi-send"></i>
                        </button>
                    </form>

                    <div class="login-footer">
                        <a asp-controller="Login" asp-action="Index" class="forgot-link">
                            <i class="bi bi-arrow-left"></i>
                            Back to Login
                        </a>
                    </div>
                </div>

                <div class="brand-footer">
                    <a href="https://jrwippel.github.io/WebAppSystems/" target="_blank" class="brand-text">JRWIT.COM</a>
                    <span class="brand-tagline">SMART SOLUTIONS FOR YOUR BUSINESS</span>
                </div>
            </div>

        </div>
    </div>

    <script src="/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
