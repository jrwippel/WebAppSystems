@using WebAppSystems.Models.Enums;
@using WebAppSystems.Models.ViewModels;
@model AttorneyFormViewModel

@{
    ViewData["Title"] = "Novo Usuário";
}

<div class="page-container">
    <div class="page-header">
        <div class="page-header-icon"><i class="bi bi-person-plus"></i></div>
        <div>
            <h2>Cadastro de Usuário</h2>
            <p>Preencha os dados do novo usuário</p>
        </div>
    </div>

    <div class="form-card">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="form-grid">
                <div class="form-field">
                    <label asp-for="Attorney.Name">Nome</label>
                    <input asp-for="Attorney.Name" class="form-control" />
                    <span asp-validation-for="Attorney.Name" class="text-danger"></span>
                </div>
                <div class="form-field">
                    <label asp-for="Attorney.Email">Email</label>
                    <input asp-for="Attorney.Email" class="form-control" />
                    <span asp-validation-for="Attorney.Email" class="text-danger"></span>
                </div>
                <div class="form-field">
                    <label asp-for="Attorney.BirthDate">Data de Nascimento</label>
                    <input asp-for="Attorney.BirthDate" class="form-control" type="date" />
                </div>
                <div class="form-field">
                    <label asp-for="Attorney.Phone">Telefone</label>
                    <input asp-for="Attorney.Phone" class="form-control" />
                </div>
                <div class="form-field">
                    <label asp-for="Attorney.DepartmentId">Área</label>
                    <select asp-for="Attorney.DepartmentId" asp-items="@(new SelectList(Model.Departments,"Id","Name"))" class="form-control"></select>
                </div>
                <div class="form-field">
                    <label asp-for="Attorney.Login">Login</label>
                    <input asp-for="Attorney.Login" class="form-control" />
                    <span asp-validation-for="Attorney.Login" class="text-danger"></span>
                </div>
                <div class="form-field">
                    <label>Perfil</label>
                    <select asp-for="Attorney.Perfil" class="form-control">
                        <option value="">Selecione</option>
                        <option value="@ProfileEnum.Admin">Administrador</option>
                        <option value="@ProfileEnum.Padrao">Padrão</option>
                        <option value="@ProfileEnum.Controladoria">Controladoria</option>
                    </select>
                </div>
                <div class="form-field">
                    <label>Senha</label>
                    <input type="password" asp-for="Attorney.Password" class="form-control" placeholder="Digite a senha" />
                </div>
            </div>

            <div class="form-checks">
                <label class="check-item">
                    <input type="checkbox" asp-for="Attorney.UseBorder" />
                    <span>Utiliza borda</span>
                </label>
                <label class="check-item">
                    <input type="checkbox" asp-for="Attorney.UseCronometroAlwaysOnTop" />
                    <span>Cronômetro Always on Top</span>
                </label>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-save"><i class="bi bi-check-lg"></i> Salvar</button>
                <a asp-action="Index" class="btn-back"><i class="bi bi-arrow-left"></i> Voltar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
