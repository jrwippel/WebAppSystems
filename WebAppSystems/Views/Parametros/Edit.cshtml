@model WebAppSystems.Models.Parametros

@{
    ViewData["Title"] = "Configurações";
}

<div class="page-container">
    <div class="page-header">
        <div class="page-header-icon"><i class="bi bi-gear"></i></div>
        <div>
            <h2>Configurações do Sistema</h2>
            <p>Gerencie o logo e dimensões do escritório</p>
        </div>
    </div>

    <div class="form-card">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="Id" />

            <div class="form-field">
                <label asp-for="Logo">Logo do Escritório</label>
                <input asp-for="Logo" class="form-control" type="file" name="logo" accept="image/*" />
                <span asp-validation-for="Logo" class="text-danger"></span>
                @if (Model?.LogoData != null)
                {
                    var src = $"data:{Model.LogoMimeType};base64,{Convert.ToBase64String(Model.LogoData)}";
                    <div class="mt-2">
                        <img src="@src" alt="Logo atual" style="max-height:80px; border-radius:6px;" />
                        <small class="text-muted d-block mt-1">Logo atual</small>
                    </div>
                }
            </div>

            <div class="form-grid">
                <div class="form-field">
                    <label asp-for="Width">Largura (px)</label>
                    <input asp-for="Width" class="form-control" />
                    <span asp-validation-for="Width" class="text-danger"></span>
                </div>
                <div class="form-field">
                    <label asp-for="Height">Altura (px)</label>
                    <input asp-for="Height" class="form-control" />
                    <span asp-validation-for="Height" class="text-danger"></span>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-save"><i class="bi bi-check-lg"></i> Salvar</button>
                <a asp-action="Index" class="btn-back"><i class="bi bi-arrow-left"></i> Voltar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
