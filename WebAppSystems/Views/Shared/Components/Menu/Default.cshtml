@using WebAppSystems.Models.Enums
@model Attorney

@{
    var isAdmin = Model.Perfil == ProfileEnum.Admin;
    var isControladoria = Model.Perfil == ProfileEnum.Controladoria;
    var showAdminItems = Model.Perfil != ProfileEnum.Padrao;
}

<style>
    .navbar {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
        box-shadow: 0 2px 8px rgba(0,0,0,0.15);
        padding: 0 12px !important;
        min-height: 44px;
        position: relative;
        z-index: 1000;
    }

    /* O container-fluid vira flex com 3 zonas: esquerda | centro | direita */
    .navbar > .container-fluid {
        display: flex !important;
        align-items: center;
        position: relative;
    }

    .navbar-left {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-shrink: 0;
    }

    .navbar-center {
        position: absolute;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        align-items: center;
    }

    /* Brand / User dropdown */
    .user-dropdown { position: relative; }

    .user-dropdown-toggle {
        background: none;
        border: none;
        color: white;
        font-size: 13px;
        font-weight: 600;
        padding: 6px 10px;
        display: flex;
        align-items: center;
        gap: 6px;
        cursor: pointer;
        border-radius: 6px;
        transition: background 0.2s;
        white-space: nowrap;
        max-width: 220px;
    }

    .user-toggle-info {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 1px;
    }

    .user-toggle-workspace {
        font-size: 12px;
        font-weight: 700;
        line-height: 1.2;
        color: white;
    }

    .user-toggle-login {
        font-size: 10px;
        font-weight: 400;
        opacity: 0.8;
        line-height: 1.2;
    }

    .user-dropdown-toggle:hover { background: rgba(255,255,255,0.12); }

    .dropdown-arrow {
        font-size: 10px;
        transition: transform 0.25s;
    }

    .user-dropdown.active .dropdown-arrow { transform: rotate(180deg); }

    .user-dropdown-menu {
        position: absolute;
        top: calc(100% + 6px);
        left: 0;
        background: white;
        border-radius: 10px;
        box-shadow: 0 8px 24px rgba(0,0,0,0.15);
        min-width: 220px;
        opacity: 0;
        visibility: hidden;
        transform: translateY(-8px);
        transition: all 0.25s ease;
        z-index: 2000;
    }

    .user-dropdown.active .user-dropdown-menu {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
    }

    .dropdown-header {
        padding: 12px 14px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 10px 10px 0 0;
    }

    .user-info { display: flex; align-items: center; gap: 10px; }

    .user-icon-large {
        font-size: 28px;
        width: 38px;
        height: 38px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255,255,255,0.2);
        border-radius: 50%;
    }

    .user-details { display: flex; flex-direction: column; color: white; }
    .user-details strong { font-size: 13px; }
    .user-email { font-size: 11px; opacity: 0.85; }

    .dd-divider { height: 1px; background: #e2e8f0; margin: 4px 0; }

    .dd-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 9px 14px;
        color: #2d3748;
        text-decoration: none;
        font-size: 13px;
        transition: background 0.15s;
    }

    .dd-item:hover { background: #f7fafc; color: #667eea; }
    .dd-item i { font-size: 14px; width: 16px; text-align: center; }
    .dd-item.logout { color: #e53e3e; }
    .dd-item.logout:hover { background: #fff5f5; color: #c53030; }

    /* Hours badge */
    .hours-today {
        display: flex;
        align-items: center;
        gap: 5px;
        padding: 4px 10px;
        background: rgba(255,255,255,0.15);
        border-radius: 20px;
        font-size: 12px;
        font-weight: 500;
        color: white;
        border: 1px solid rgba(255,255,255,0.2);
        white-space: nowrap;
    }

    .hours-today strong { color: #ffeb3b; font-size: 12px; }

    /* Nav links */
    .navbar-nav { display: flex; align-items: center; gap: 2px; padding: 0; margin: 0; }
    .nav-item { list-style: none; }

    .nav-link {
        color: rgba(255,255,255,0.92) !important;
        padding: 6px 10px !important;
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: 13px;
        font-weight: 500;
        border-radius: 6px;
        transition: background 0.2s;
        white-space: nowrap;
    }

    .nav-link i { font-size: 14px; }
    .nav-link:hover { background: rgba(255,255,255,0.15) !important; color: white !important; }
    .nav-link.active-page { background: rgba(255,255,255,0.2) !important; }

    /* Gerenciar dropdown */
    .gerenciar-dropdown { position: relative; }

    .gerenciar-toggle {
        color: rgba(255,255,255,0.92) !important;
        padding: 6px 10px !important;
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: 13px;
        font-weight: 500;
        border-radius: 6px;
        transition: background 0.2s;
        cursor: pointer;
        background: none;
        border: none;
        white-space: nowrap;
    }

    .gerenciar-toggle:hover { background: rgba(255,255,255,0.15) !important; }
    .gerenciar-dropdown.active .gerenciar-toggle { background: rgba(255,255,255,0.2) !important; }

    .gerenciar-menu {
        position: absolute;
        top: calc(100% + 6px);
        left: 0;
        background: white;
        border-radius: 10px;
        box-shadow: 0 8px 24px rgba(0,0,0,0.15);
        min-width: 200px;
        opacity: 0;
        visibility: hidden;
        transform: translateY(-8px);
        transition: all 0.25s ease;
        z-index: 2000;
        padding: 6px 0;
    }

    .gerenciar-dropdown.active .gerenciar-menu {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
    }

    .gerenciar-section-label {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.08em;
        color: #a0aec0;
        padding: 8px 14px 4px;
        text-transform: uppercase;
    }

    .gerenciar-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px 14px;
        color: #2d3748;
        text-decoration: none;
        font-size: 13px;
        transition: background 0.15s;
    }

    .gerenciar-item:hover { background: #f7fafc; color: #667eea; }
    .gerenciar-item i { font-size: 14px; width: 16px; text-align: center; color: #667eea; }

    /* Logo */
    .office-logo-small {
        max-height: 28px;
        max-width: 90px;
        object-fit: contain;
        border-radius: 3px;
    }

    /* Office logo + name above flags */
    .navbar-right-flags {
        margin-left: auto;
        display: flex;
        align-items: center;
        flex-shrink: 0;
    }

    /* Language flags */
    .language-flags-group {
        display: flex;
        gap: 4px;
        align-items: center;
    }

    .flag-btn {
        background: rgba(255,255,255,0.12);
        border: 1px solid rgba(255,255,255,0.2);
        cursor: pointer;
        padding: 2px 4px;
        border-radius: 3px;
        transition: all 0.2s;
        opacity: 0.65;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .flag-btn:hover { opacity: 1; background: rgba(255,255,255,0.22); }
    .flag-btn.active { opacity: 1; background: rgba(255,255,255,0.28); border-color: rgba(255,255,255,0.5); }

    .flag-icon { width: 20px; height: 13px; border-radius: 2px; display: block; }

    /* Navbar right section */
    .navbar-right {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-left: auto;
    }

    .navbar-toggler {
        border-color: rgba(255,255,255,0.3) !important;
    }

    .navbar-toggler-icon {
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 30 30'%3e%3cpath stroke='rgba(255,255,255,0.9)' stroke-linecap='round' stroke-miterlimit='10' stroke-width='2' d='M4 7h22M4 15h22M4 23h22'/%3e%3c/svg%3e") !important;
    }

    @@media (max-width: 767px) {
        .navbar-center { position: static !important; transform: none !important; }

        /* Collapse panel */
        .navbar-collapse {
            flex-direction: column !important;
            align-items: flex-start !important;
            width: 100% !important;
            padding: 8px 0 4px !important;
        }
        .navbar-collapse:not(.show) { display: none !important; }
        .navbar-collapse.show { display: flex !important; }
        .navbar-nav {
            flex-direction: column !important;
            align-items: flex-start !important;
            padding: 4px 0 !important;
            gap: 2px !important;
            width: 100% !important;
        }
        .nav-item { width: 100%; }
        .nav-link {
            width: 100% !important;
            padding: 12px 14px !important;
            font-size: 15px !important;
            border-radius: 8px !important;
        }
        .hours-today { font-size: 13px !important; margin: 4px 0 !important; }

        /* Gerenciar dropdown — estático no mobile */
        .gerenciar-menu {
            position: static !important;
            opacity: 1 !important;
            visibility: visible !important;
            transform: none !important;
            box-shadow: none !important;
            border-radius: 8px !important;
            background: rgba(255,255,255,0.08) !important;
            margin: 4px 0 4px 16px !important;
            display: none !important;
            padding: 4px 0 !important;
        }
        .gerenciar-dropdown.active .gerenciar-menu { display: block !important; }
        .gerenciar-item {
            color: rgba(255,255,255,0.9) !important;
            padding: 12px 16px !important;
            font-size: 14px !important;
        }
        .gerenciar-item:hover { background: rgba(255,255,255,0.1) !important; color: white !important; }
        .gerenciar-item i { color: rgba(255,255,255,0.7) !important; }
        .gerenciar-section-label { color: rgba(255,255,255,0.5) !important; }
        .dd-divider { background: rgba(255,255,255,0.15) !important; }

        .navbar-right-flags { margin-left: 0 !important; padding: 8px 0 !important; width: 100% !important; }
        .navbar-left { flex-wrap: wrap; }
    }
</style>

<!-- LEFT: user dropdown only -->
<div class="navbar-left">
    <div class="user-dropdown" id="userDropdown">
        <button class="user-dropdown-toggle" id="userDropdownToggle"
                title="Eberhardt, Carrascoza, Bossi, Silva, Matteussi &amp; Costa Beber Advogados">
            <div class="user-toggle-info">
                <span class="user-toggle-workspace">Eberhardt, Carrascoza, BSM &amp; CB Adv.</span>
                <span class="user-toggle-login">@Model.Login</span>
            </div>
            <i class="bi bi-chevron-down dropdown-arrow"></i>
        </button>

        <div class="user-dropdown-menu" id="userDropdownMenu">
            <div class="dropdown-header">
                <div class="user-info">
                    <span class="user-icon-large">👤</span>
                    <div class="user-details">
                        <strong>@Model.Name</strong>
                        <span class="user-email">@Model.Login</span>
                    </div>
                </div>
            </div>
            <div class="dd-divider"></div>
            <a class="dd-item" asp-controller="AlterarSenha" asp-action="Index">
                <i class="bi bi-shield-lock"></i><span data-i18n="menu.senha">Senha</span>
            </a>
            <a class="dd-item" asp-controller="Parametros" asp-action="Index">
                <i class="bi bi-gear"></i><span data-i18n="menu.configuracoes">Configurações</span>
            </a>
            <a class="dd-item" asp-controller="Home" asp-action="About">
                <i class="bi bi-info-circle"></i><span data-i18n="menu.about">Sobre</span>
            </a>
            <div class="dd-divider"></div>
            <a class="dd-item logout" asp-controller="Login" asp-action="Sair">
                <i class="bi bi-box-arrow-right"></i><span data-i18n="menu.sair">Sair</span>
            </a>
        </div>
    </div>
</div>

<!-- Collapse toggle (mobile) -->
<button class="navbar-toggler" type="button" id="navbarToggler"
        aria-expanded="false" aria-label="Toggle navigation">
    <span class="navbar-toggler-icon"></span>
</button>

<!-- CENTER: Nav items -->
<div class="navbar-collapse collapse d-sm-inline-flex" id="navbarCollapse">
    <div class="navbar-center">
        <ul class="navbar-nav">
            <li class="nav-item">
                <div class="hours-today">
                    <i class="bi bi-clock-history"></i>
                    <span data-i18n="menu.hourstoday">Hoje:</span>
                    <strong>@ViewBag.HorasHoje.ToString("F1")h</strong>
                </div>
            </li>
                <a class="nav-link" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-house-door"></i>
                    <span data-i18n="menu.home">Home</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-controller="TimeTracker" asp-action="Index">
                    <i class="bi bi-stopwatch"></i>
                    <span data-i18n="menu.timetracker">Time Tracker</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-controller="ProcessRecord" asp-action="Index">
                    <i class="bi bi-file-earmark-text"></i>
                    <span data-i18n="menu.relatorios">Relatórios</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-controller="ProcessRecords" asp-action="Index">
                    <i class="bi bi-list-check"></i>
                    <span data-i18n="menu.atividades">Atividades</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-controller="Calendar" asp-action="Index">
                    <i class="bi bi-calendar3"></i>
                    <span data-i18n="menu.calendario">Calendário</span>
                </a>
            </li>

            @if (showAdminItems)
            {
                <li class="nav-item gerenciar-dropdown" id="gerenciarDropdown">
                    <button class="gerenciar-toggle" id="gerenciarToggle">
                        <i class="bi bi-grid"></i>
                        <span>Gerenciar</span>
                        <i class="bi bi-chevron-down dropdown-arrow" style="font-size:10px;"></i>
                    </button>
                    <div class="gerenciar-menu" id="gerenciarMenu">
                        <div class="gerenciar-section-label">Cadastros</div>
                        <a class="gerenciar-item" asp-controller="Attorneys" asp-action="Index">
                            <i class="bi bi-people"></i><span data-i18n="menu.usuarios">Usuários</span>
                        </a>
                        <a class="gerenciar-item" asp-controller="Clients" asp-action="Index">
                            <i class="bi bi-person-badge"></i><span data-i18n="menu.clientes">Clientes</span>
                        </a>
                        <a class="gerenciar-item" asp-controller="Departments" asp-action="Index">
                            <i class="bi bi-building"></i><span data-i18n="menu.area">Área</span>
                        </a>
                        @if (isAdmin)
                        {
                            <div class="dd-divider"></div>
                            <div class="gerenciar-section-label">Financeiro</div>
                            <a class="gerenciar-item" asp-controller="ValorClientes" asp-action="Index">
                                <i class="bi bi-cash-coin"></i><span data-i18n="menu.valores">Valores</span>
                            </a>
                            <a class="gerenciar-item" asp-controller="Mensalistas" asp-action="Index">
                                <i class="bi bi-calendar-check"></i><span data-i18n="menu.mensalistas">Mensalistas</span>
                            </a>
                            <a class="gerenciar-item" asp-controller="Mensalista" asp-action="Index">
                                <i class="bi bi-graph-up-arrow"></i><span data-i18n="menu.resultados">Resultados</span>
                            </a>
                            <a class="gerenciar-item" asp-controller="PercentualAreas" asp-action="Index">
                                <i class="bi bi-percent"></i><span data-i18n="menu.percentuais">Percentuais</span>
                            </a>
                        }
                    </div>
                </li>
            }
        </ul>
    </div>

    <!-- RIGHT: flags -->
    <div class="navbar-right-flags">
        <div class="language-flags-group">
            <button class="flag-btn active" data-lang="pt" title="Português">
                <svg class="flag-icon" viewBox="0 0 36 24" xmlns="http://www.w3.org/2000/svg">
                    <rect width="36" height="24" fill="#009b3a"/>
                    <path d="M18 3 L33 12 L18 21 L3 12 Z" fill="#fedf00"/>
                    <circle cx="18" cy="12" r="4" fill="#002776"/>
                </svg>
            </button>
            <button class="flag-btn" data-lang="en" title="English">
                <svg class="flag-icon" viewBox="0 0 36 24" xmlns="http://www.w3.org/2000/svg">
                    <rect width="36" height="24" fill="#012169"/>
                    <path d="M0 0 L36 24 M36 0 L0 24" stroke="#fff" stroke-width="4"/>
                    <path d="M0 0 L36 24 M36 0 L0 24" stroke="#C8102E" stroke-width="2.5"/>
                    <path d="M18 0 V24 M0 12 H36" stroke="#fff" stroke-width="6"/>
                    <path d="M18 0 V24 M0 12 H36" stroke="#C8102E" stroke-width="3.5"/>
                </svg>
            </button>
            <button class="flag-btn" data-lang="es" title="Español">
                <svg class="flag-icon" viewBox="0 0 36 24" xmlns="http://www.w3.org/2000/svg">
                    <rect width="36" height="6" fill="#AA151B"/>
                    <rect y="6" width="36" height="12" fill="#F1BF00"/>
                    <rect y="18" width="36" height="6" fill="#AA151B"/>
                </svg>
            </button>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
    // User dropdown
    const userToggle = document.getElementById('userDropdownToggle');
    const userDropdown = document.getElementById('userDropdown');
    if (userToggle) {
        userToggle.addEventListener('click', function (e) {
            e.stopPropagation();
            userDropdown.classList.toggle('active');
            gerenciarDropdown?.classList.remove('active');
        });
    }

    // Gerenciar dropdown
    const gerenciarToggle = document.getElementById('gerenciarToggle');
    const gerenciarDropdown = document.getElementById('gerenciarDropdown');
    if (gerenciarToggle) {
        gerenciarToggle.addEventListener('click', function (e) {
            e.stopPropagation();
            gerenciarDropdown.classList.toggle('active');
            userDropdown?.classList.remove('active');
        });
    }

    // Navbar toggler (mobile)
    const navbarToggler = document.getElementById('navbarToggler');
    const navbarCollapse = document.getElementById('navbarCollapse');
    if (navbarToggler && navbarCollapse) {
        function checkViewport() {
            if (window.innerWidth >= 768) {
                navbarCollapse.classList.add('show');
            }
        }
        checkViewport();
        window.addEventListener('resize', checkViewport);

        navbarToggler.addEventListener('click', function () {
            navbarCollapse.classList.toggle('show');
            navbarToggler.setAttribute('aria-expanded', navbarCollapse.classList.contains('show'));
        });

        // Fechar ao clicar em link no mobile (exceto Gerenciar)
        navbarCollapse.querySelectorAll('a.nav-link, a.gerenciar-item').forEach(function(link) {
            link.addEventListener('click', function() {
                if (window.innerWidth < 768) {
                    navbarCollapse.classList.remove('show');
                    navbarToggler.setAttribute('aria-expanded', 'false');
                }
            });
        });
    }

    // Close dropdowns on outside click
    document.addEventListener('click', function () {
        userDropdown?.classList.remove('active');
        gerenciarDropdown?.classList.remove('active');
    });
});
</script>
